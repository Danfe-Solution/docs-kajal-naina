
## Mermaid ERD Diagram

```mermaid
erDiagram

    FiscalYears {
        int fiscal_year_id PK
        string name
        date start_date
        date end_date
        bool is_active
    }

    VoucherTypes {
        int voucher_type_id PK
        string code
        string name
        string prefix
        bool affects_stock
        bool is_active
    }

    LedgerTags {
        int ledger_tag_id PK
        string name
        string description
        string standard "e.g., IFRS, GAAP, Local"
    }

    FiscalYearVoucherConfig {
        int config_id PK
        int fiscal_year_id FK
        int voucher_type_id FK
        int starting_number
        string format
        bool is_active
    }

    LedgerTypes {
        int ledger_type_id PK
        string name "Assets, Liabilities, Income, Expenses"
        string normal_balance "Debit/Credit"
    }

    LedgerCategories {
        int ledger_category_id PK
        string name
        int parent_category_id FK "nullable, self-reference"
        int ledger_type_id FK
        bool is_active
    }

    Ledgers {
        int ledger_id PK
        string name
        int ledger_type_id FK
        int ledger_category_id FK
        int ledger_tag_id FK
        string code
        bool is_active
    }

    Vouchers {
        int voucher_id PK
        int fiscal_year_id FK
        int voucher_type_id FK
        string voucher_no
        date voucher_date
        string reference
        string narration
        decimal total_debit
        decimal total_credit
        int created_by_user_id FK
        string status
    }

    VoucherDetails {
        int voucher_detail_id PK
        int voucher_id FK
        int ledger_id FK
        decimal debit
        decimal credit
        string narration
    }

    FiscalYears ||--o{ FiscalYearVoucherConfig : "configures"
    FiscalYears ||--o{ Vouchers : "belongs to"

    VoucherTypes ||--o{ FiscalYearVoucherConfig : "used in"
    VoucherTypes ||--o{ Vouchers : "typed as"

    LedgerTags ||--o{ Ledgers : "tags"

    LedgerTypes ||--o{ LedgerCategories : "categorizes"
    LedgerTypes ||--o{ Ledgers : "typed as"

    LedgerCategories ||--o{ LedgerCategories : "parent-child"
    LedgerCategories ||--o{ Ledgers : "groups"

    Vouchers ||--o{ VoucherDetails : "contains"
    VoucherDetails ||--o{ Ledgers : "affects"
